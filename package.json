{
    "name": "chefu-academy-sdk",
    "version": "1.0.4",
    "description": "A TypeScript SDK for the CheFu Academy platform",
    "author": "Kurisani Maluleke",
    "license": "MIT",
    "homepage": "https://github.com/CheFu-code/CheFu-Academy-SDK#readme",
    "repository": {
        "type": "git",
        "url": "https://github.com/CheFu-code/CheFu-Academy-SDK.git"
    },
    "bugs": {
        "url": "https://github.com/CheFu-code/CheFu-Academy-SDK/issues"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts --dts --format esm,cjs --clean",
        "dev": "tsup src/index.ts --watch --dts --format esm,cjs",
        "prepare": "npm run build"
    },
    "keywords": [
        "chefu",
        "academy",
        "sdk",
        "typescript",
        "api-client",
        "education"
    ],
    "devDependencies": {
        "typescript": "^5.9.3",
        "tsup": "^8.5.1",
        "@types/node": "^25.0.10"
    },
    "dependencies": {
        "axios": "^1.13.2",
        "validator": "^13.15.26",
        "@types/validator": "^13.15.10"
    },
    "engines": {
        "node": ">=18"
    }
}